{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",                      /* Padrão moderno e estável */
    "moduleResolution": "Node16",            /* Resolve o erro TS5107 */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "exemplo.ts"],
  "exclude": ["node_modules"]
}